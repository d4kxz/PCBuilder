@page
@model PCBuilder.Pages.Admin.DataSourcesModel
@{
    ViewData["Title"] = "Источники данных | Админ";
    Layout = "_Layout";
}

<style>
    /* ── Общие ────────────────────────────────────────────────── */
    .admin-wrap { max-width: 1100px; margin: 0 auto; padding: 32px 16px; }

    .admin-title { font-size: 1.6rem; font-weight: 700; color: #f1f3f5; }
    .admin-sub   { color: #6c757d; font-size: .9rem; margin-top: 4px; }

    /* ── Карточка источника ────────────────────────────────────── */
    .ds-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px; padding: 20px;
        margin-bottom: 16px;
        transition: border-color .2s;
    }
    .ds-card:hover { border-color: rgba(255,255,255,0.14); }
    .ds-card-header { display: flex; align-items: center; justify-content: space-between; gap: 12px; }

    .ds-name  { font-size: 1rem; font-weight: 600; color: #f1f3f5; }
    .ds-type  { font-size: .75rem; background: rgba(77,171,247,0.12);
                color: var(--accent,#4dabf7); border-radius: 6px; padding: 2px 8px; }

    .ds-meta  { font-size: .8rem; color: #6c757d; margin-top: 6px; }

    .badge-success { background: rgba(64,192,87,0.15); color: #51cf66; border-radius: 6px; padding: 2px 8px; font-size: .75rem; }
    .badge-error   { background: rgba(240,62,62,0.15);  color: #ff6b6b; border-radius: 6px; padding: 2px 8px; font-size: .75rem; }
    .badge-running { background: rgba(250,176,5,0.15);  color: #fcc419; border-radius: 6px; padding: 2px 8px; font-size: .75rem; }
    .badge-never   { background: rgba(255,255,255,0.06);color: #6c757d; border-radius: 6px; padding: 2px 8px; font-size: .75rem; }

    /* ── Кнопки действий ──────────────────────────────────────── */
    .btn-ds {
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px; color: #adb5bd; font-size: .8rem; padding: 5px 12px;
        cursor: pointer; transition: all .15s; display: inline-flex; align-items: center; gap: 5px;
        text-decoration: none;
    }
    .btn-ds:hover { background: rgba(255,255,255,0.12); color: #fff; }
    .btn-ds.sync  { border-color: rgba(77,171,247,0.3); color: var(--accent,#4dabf7); }
    .btn-ds.sync:hover { background: rgba(77,171,247,0.12); }
    .btn-ds.danger { border-color: rgba(240,62,62,0.3); color: #ff6b6b; }
    .btn-ds.danger:hover { background: rgba(240,62,62,0.1); }

    /* ── Кнопка добавить ──────────────────────────────────────── */
    .btn-add-ds {
        background: linear-gradient(135deg, rgba(77,171,247,0.15), rgba(77,171,247,0.08));
        border: 1px solid rgba(77,171,247,0.3); border-radius: 10px;
        color: var(--accent,#4dabf7); font-size: .9rem; font-weight: 600;
        padding: 10px 20px; cursor: pointer; transition: all .2s;
        display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-add-ds:hover { background: rgba(77,171,247,0.2); border-color: rgba(77,171,247,.5); }

    /* ── Форма (modal-style, на странице) ─────────────────────── */
    .form-panel {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(77,171,247,0.2);
        border-radius: 16px; padding: 28px;
        margin-bottom: 24px; display: none;
    }
    .form-panel.open { display: block; }

    .form-section-title {
        font-size: .75rem; font-weight: 700; letter-spacing: .08em;
        text-transform: uppercase; color: #6c757d; margin: 20px 0 10px;
    }

    .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .form-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }
    @@media(max-width:700px) { .form-grid-2,.form-grid-3 { grid-template-columns: 1fr; } }

    .form-group label { font-size: .8rem; color: #adb5bd; margin-bottom: 5px; display: block; }
    .form-control-dark {
        background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px; color: #fff; padding: 8px 12px; width: 100%;
        font-size: .88rem; outline: none; transition: border-color .2s;
    }
    .form-control-dark:focus { border-color: rgba(77,171,247,0.4); }
    .form-control-dark option { background: #1a1a2e; }

    /* ── Маппинг колонок ──────────────────────────────────────── */
    .mapping-hint { font-size: .75rem; color: #6c757d; margin-top: 3px; }

    /* ── Пустое состояние ─────────────────────────────────────── */
    .empty-state {
        text-align: center; padding: 60px 20px; color: #6c757d;
        border: 1px dashed rgba(255,255,255,0.08); border-radius: 14px;
    }
    .empty-state i { font-size: 2.5rem; margin-bottom: 12px; display: block; }

    /* ── Загрузка файла ───────────────────────────────────────── */
    .file-drop-zone {
        border: 2px dashed rgba(255,255,255,0.12); border-radius: 10px;
        padding: 20px; text-align: center; color: #6c757d; font-size: .85rem;
        cursor: pointer; transition: border-color .2s;
    }
    .file-drop-zone:hover { border-color: rgba(77,171,247,0.3); color: #adb5bd; }
    .file-drop-zone input[type=file] { display: none; }
</style>

<div class="admin-wrap">

    <!-- ── Заголовок ─────────────────────────────────────────── -->
    <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
        <div>
            <div class="admin-title"><i class="bi bi-database-gear me-2"></i>Источники данных</div>
            <div class="admin-sub">Подключите базу данных вашей компании для синхронизации товаров</div>
        </div>
        <button class="btn-add-ds" id="toggleFormBtn">
            <i class="bi bi-plus-lg"></i> Добавить источник
        </button>
    </div>

    <!-- ── Форма добавления ───────────────────────────────────── -->
    <div class="form-panel" id="addForm">
        <h5 class="fw-bold mb-3" style="color:#f1f3f5">
            <i class="bi bi-plug me-2" style="color:var(--accent,#4dabf7)"></i>
            Новый источник данных
        </h5>

        <div class="form-grid-2">
            <div class="form-group">
                <label>Название источника *</label>
                <input class="form-control-dark" id="f_name" placeholder="напр. База DNS Новосибирск" />
            </div>
            <div class="form-group">
                <label>Тип источника *</label>
                <select class="form-control-dark" id="f_type" onchange="onTypeChange()">
                    <option value="">— Выберите тип —</option>
                    <option value="1">SQL Server (1С, корп. ERP)</option>
                    <option value="2">MySQL / MariaDB</option>
                    <option value="3">PostgreSQL</option>
                    <option value="4">SQLite</option>
                    <option value="5">Excel (.xlsx)</option>
                    <option value="6">CSV файл</option>
                    <option value="7">XML / прайс-лист</option>
                </select>
            </div>
        </div>

        <!-- SQL-источники -->
        <div id="section_sql" style="display:none">
            <div class="form-section-title">Подключение к базе данных</div>
            <div class="form-group mb-3">
                <label>Строка подключения (Connection String) *</label>
                <input class="form-control-dark" id="f_conn" placeholder="" />
                <div class="mapping-hint" id="conn_hint"></div>
            </div>
            <div class="form-grid-2">
                <div class="form-group">
                    <label>Таблица с товарами</label>
                    <div class="d-flex gap-2">
                        <input class="form-control-dark" id="f_table" placeholder="products" style="flex:1" />
                        <button class="btn-ds" onclick="loadTables()"><i class="bi bi-arrow-repeat"></i> Найти</button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Схема (необязательно)</label>
                    <input class="form-control-dark" id="f_schema" placeholder="dbo / public" />
                </div>
            </div>
            <div id="tables_list" class="mt-2" style="display:none">
                <div class="mapping-hint mb-1">Найденные таблицы — кликните чтобы выбрать:</div>
                <div id="tables_chips" class="d-flex flex-wrap gap-2"></div>
            </div>
        </div>

        <!-- Файловые источники -->
        <div id="section_file" style="display:none">
            <div class="form-section-title">Файл данных</div>
            <label class="file-drop-zone" for="f_file_input">
                <i class="bi bi-cloud-upload" style="font-size:1.5rem; display:block; margin-bottom:8px"></i>
                <span id="file_label">Нажмите или перетащите файл сюда</span>
                <input type="file" id="f_file_input" accept=".xlsx,.csv,.xml" onchange="onFileSelect(this)" />
            </label>
            <div id="f_file_path_display" class="mapping-hint mt-2"></div>

            <!-- XML: путь к элементу -->
            <div id="xml_path_section" style="display:none" class="mt-3">
                <div class="form-group">
                    <label>Имя XML-элемента товара</label>
                    <input class="form-control-dark" id="f_xml_item" placeholder="product" />
                    <div class="mapping-hint">Например, если XML выглядит как &lt;offer&gt;...&lt;/offer&gt;, введите: offer</div>
                </div>
            </div>

            <!-- Excel: лист -->
            <div id="excel_sheet_section" style="display:none" class="mt-3">
                <div class="form-group">
                    <label>Лист Excel (необязательно)</label>
                    <input class="form-control-dark" id="f_sheet" placeholder="Лист1" />
                </div>
            </div>
        </div>

        <!-- Маппинг колонок (показываем для всех типов) -->
        <div id="section_mapping">
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div class="form-section-title" style="margin:0">Маппинг колонок</div>
                <button class="btn-ds" onclick="loadColumns()" style="font-size:.75rem">
                    <i class="bi bi-arrow-repeat"></i> Загрузить колонки
                </button>
            </div>
            <div class="mapping-hint mb-3">Укажите какая колонка в вашей таблице соответствует каждому полю</div>

            <div id="column_hints" class="d-flex flex-wrap gap-2 mb-3" style="display:none!important"></div>

            <div class="form-grid-3">
                <div class="form-group">
                    <label>Название товара *</label>
                    <input class="form-control-dark mapping-col" id="m_name"  placeholder="name / наименование" />
                </div>
                <div class="form-group">
                    <label>Категория</label>
                    <input class="form-control-dark mapping-col" id="m_cat"   placeholder="category / раздел" />
                </div>
                <div class="form-group">
                    <label>Цена *</label>
                    <input class="form-control-dark mapping-col" id="m_price" placeholder="price / цена" />
                </div>
                <div class="form-group">
                    <label>Характеристики</label>
                    <input class="form-control-dark mapping-col" id="m_specs" placeholder="specs / описание" />
                </div>
                <div class="form-group">
                    <label>Ссылка на товар</label>
                    <input class="form-control-dark mapping-col" id="m_url"   placeholder="url / ссылка" />
                </div>
                <div class="form-group">
                    <label>Изображение</label>
                    <input class="form-control-dark mapping-col" id="m_img"   placeholder="image / картинка" />
                </div>
            </div>

            <div class="form-grid-2 mt-2">
                <div class="form-group">
                    <label>Название магазина по умолчанию</label>
                    <input class="form-control-dark" id="m_merchant" placeholder="напр. DNS" />
                    <div class="mapping-hint">Используется если нет колонки с названием магазина</div>
                </div>
                <div class="form-group">
                    <label>Категория по умолчанию</label>
                    <select class="form-control-dark" id="m_default_cat">
                        <option value="">— Определить автоматически —</option>
                        <option value="Процессор">Процессор</option>
                        <option value="Материнская плата">Материнская плата</option>
                        <option value="Видеокарта">Видеокарта</option>
                        <option value="Оперативная память">Оперативная память</option>
                        <option value="Накопитель SSD">Накопитель SSD</option>
                        <option value="Блок питания">Блок питания</option>
                        <option value="Корпус">Корпус</option>
                        <option value="Охлаждение">Охлаждение</option>
                    </select>
                    <div class="mapping-hint">Если все товары в файле одной категории</div>
                </div>
            </div>
        </div>

        <!-- Авто-синхронизация -->
        <div class="form-section-title">Авто-синхронизация</div>
        <div class="form-grid-2">
            <div class="form-group d-flex align-items-center gap-3">
                <input type="checkbox" id="f_autosync" class="form-check-input" />
                <label for="f_autosync" style="cursor:pointer; margin:0">Включить авто-обновление</label>
            </div>
            <div class="form-group">
                <label>Интервал (часов)</label>
                <input class="form-control-dark" id="f_interval" type="number" value="24" min="1" max="168" />
            </div>
        </div>

        <!-- Кнопки -->
        <div class="d-flex gap-2 mt-4 flex-wrap">
            <button class="btn-ds sync" onclick="testConnection()">
                <i class="bi bi-plug"></i> Проверить подключение
            </button>
            <button class="btn-add-ds" style="font-size:.85rem; padding:8px 16px" onclick="saveDataSource()">
                <i class="bi bi-check-lg"></i> Сохранить и синхронизировать
            </button>
            <button class="btn-ds" onclick="closeForm()">Отмена</button>
        </div>
        <div id="form_status" class="mt-3" style="font-size:.85rem"></div>
    </div>

    <!-- ── Список источников ──────────────────────────────────── -->
    <div id="dsList">
        @if (!Model.DataSources.Any())
        {
            <div class="empty-state">
                <i class="bi bi-database-slash"></i>
                <div class="fw-semibold mb-1" style="color:#adb5bd">Источников данных пока нет</div>
                <div class="small">Нажмите «Добавить источник» чтобы подключить вашу базу данных</div>
            </div>
        }
        else
        {
            @foreach (var ds in Model.DataSources)
            {
                var statusBadge = ds.LastSyncStatus switch
                {
                    PCBuilder.Models.SyncStatus.Success => "<span class='badge-success'>✓ Успешно</span>",
                    PCBuilder.Models.SyncStatus.Error   => "<span class='badge-error'>✗ Ошибка</span>",
                    PCBuilder.Models.SyncStatus.Running => "<span class='badge-running'>⟳ Выполняется</span>",
                    _                                   => "<span class='badge-never'>Не синхронизировался</span>"
                };

                <div class="ds-card" id="ds-@ds.Id">
                    <div class="ds-card-header">
                        <div>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="ds-name">@ds.Name</span>
                                <span class="ds-type">@ds.Type</span>
                                @Html.Raw(statusBadge)
                            </div>
                            <div class="ds-meta">
                                @if (ds.LastSyncAt.HasValue)
                                {
                                    <span>Последняя синхронизация: @ds.LastSyncAt.Value.ToString("dd.MM.yyyy HH:mm")</span>
                                    <span class="mx-2">·</span>
                                    <span>Загружено: @ds.SyncedCount записей</span>
                                }
                                @if (!string.IsNullOrEmpty(ds.LastSyncError))
                                {
                                    <div class="text-danger mt-1">@ds.LastSyncError</div>
                                }
                                @if (ds.AutoSync)
                                {
                                    <span class="ms-2"><i class="bi bi-arrow-repeat"></i> Авто раз в @ds.AutoSyncIntervalH ч.</span>
                                }
                            </div>
                        </div>
                        <div class="d-flex gap-2 flex-shrink-0">
                            <button class="btn-ds sync" onclick="syncSource(@ds.Id)">
                                <i class="bi bi-arrow-repeat"></i> Синхр.
                            </button>
                            <button class="btn-ds danger" onclick="deleteSource(@ds.Id)">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

</div>

@section Scripts {
<script>
// ── Состояние ──────────────────────────────────────────────────────
let uploadedFilePath = '';

// ── Переключение типа источника ────────────────────────────────────
function onTypeChange() {
    const t = parseInt(document.getElementById('f_type').value);
    const isSql  = t >= 1 && t <= 4;
    const isFile = t >= 5 && t <= 7;

    document.getElementById('section_sql').style.display  = isSql  ? 'block' : 'none';
    document.getElementById('section_file').style.display = isFile ? 'block' : 'none';

    document.getElementById('xml_path_section').style.display   = (t === 7) ? 'block' : 'none';
    document.getElementById('excel_sheet_section').style.display = (t === 5) ? 'block' : 'none';

    // Подсказки строки подключения
    const hints = {
        1: 'Server=myServer;Database=myDB;User Id=sa;Password=myPass;',
        2: 'Server=localhost;Port=3306;Database=shop;Uid=root;Pwd=pass;',
        3: 'Host=localhost;Port=5432;Database=shop;Username=postgres;Password=pass;',
        4: 'Data Source=C:\\path\\to\\db.sqlite;',
    };
    document.getElementById('conn_hint').textContent = hints[t] || '';
}

// ── Загрузка файла ──────────────────────────────────────────────────
async function onFileSelect(input) {
    const file = input.files[0];
    if (!file) return;

    const formData = new FormData();
    formData.append('file', file);

    setStatus('⟳ Загружаю файл...', 'info');
    try {
        const res  = await fetch('?handler=UploadFile', { method: 'POST', body: formData,
            headers: { 'RequestVerificationToken': getToken() } });
        const data = await res.json();
        if (data.path) {
            uploadedFilePath = data.path;
            document.getElementById('file_label').textContent = '✓ ' + file.name;
            setStatus('✓ Файл загружен', 'success');
        } else {
            setStatus('✗ ' + (data.error || 'Ошибка загрузки'), 'error');
        }
    } catch(e) {
        setStatus('✗ Ошибка сети', 'error');
    }
}

// ── Загрузить таблицы ───────────────────────────────────────────────
async function loadTables() {
    const payload = buildPayload();
    setStatus('⟳ Запрашиваю список таблиц...', 'info');
    try {
        const res  = await fetch('?handler=GetTables', {
            method: 'POST', headers: jsonHeaders(), body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.tables?.length) {
            document.getElementById('tables_list').style.display = 'block';
            document.getElementById('tables_chips').innerHTML = data.tables.map(t =>
                `<span class="btn-ds" style="cursor:pointer" onclick="selectTable('${t}')">${t}</span>`
            ).join('');
            setStatus('', '');
        } else {
            setStatus('Таблицы не найдены — проверьте строку подключения', 'error');
        }
    } catch(e) { setStatus('✗ Ошибка: ' + e.message, 'error'); }
}

function selectTable(name) {
    document.getElementById('f_table').value = name;
    loadColumns();
}

// ── Загрузить колонки ───────────────────────────────────────────────
async function loadColumns() {
    const payload = buildPayload();
    if (!payload.tableName && !payload.filePath) {
        setStatus('Сначала укажите таблицу или загрузите файл', 'error'); return;
    }
    setStatus('⟳ Читаю колонки...', 'info');
    try {
        const res  = await fetch('?handler=GetColumns', {
            method: 'POST', headers: jsonHeaders(), body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.columns?.length) {
            const chips = document.getElementById('column_hints');
            chips.style.display = 'flex';
            chips.innerHTML = '<span class="mapping-hint me-2">Колонки:</span>' +
                data.columns.map(c =>
                    `<span class="btn-ds" style="cursor:pointer;font-size:.72rem" onclick="fillMapping('${c}')">${c}</span>`
                ).join('');
            setStatus('✓ Загружено ' + data.columns.length + ' колонок', 'success');
        }
    } catch(e) { setStatus('✗ ' + e.message, 'error'); }
}

// Подставить колонку в активное поле маппинга
let lastFocusedMapping = null;
document.querySelectorAll('.mapping-col').forEach(el => {
    el.addEventListener('focus', () => lastFocusedMapping = el);
});
function fillMapping(col) {
    if (lastFocusedMapping) lastFocusedMapping.value = col;
}

// ── Проверить подключение ───────────────────────────────────────────
async function testConnection() {
    const payload = buildPayload();
    setStatus('⟳ Проверяю подключение...', 'info');
    try {
        const res  = await fetch('?handler=TestConnection', {
            method: 'POST', headers: jsonHeaders(), body: JSON.stringify(payload)
        });
        const data = await res.json();
        setStatus(data.ok ? '✓ Подключение успешно!' : '✗ ' + data.error,
                  data.ok ? 'success' : 'error');
    } catch(e) { setStatus('✗ ' + e.message, 'error'); }
}

// ── Сохранить источник ──────────────────────────────────────────────
async function saveDataSource() {
    const payload = buildPayload();
    if (!payload.name)  { setStatus('Укажите название', 'error'); return; }
    if (!payload.type)  { setStatus('Выберите тип источника', 'error'); return; }
    if (!payload.colName)  { setStatus('Укажите колонку с названием', 'error'); return; }
    if (!payload.colPrice) { setStatus('Укажите колонку с ценой', 'error'); return; }

    setStatus('⟳ Сохраняю и запускаю синхронизацию...', 'info');
    try {
        const res  = await fetch('?handler=SaveAndSync', {
            method: 'POST', headers: jsonHeaders(), body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.ok) {
            setStatus('✓ ' + data.message, 'success');
            setTimeout(() => location.reload(), 1500);
        } else {
            setStatus('✗ ' + data.error, 'error');
        }
    } catch(e) { setStatus('✗ ' + e.message, 'error'); }
}

// ── Синхронизировать существующий источник ─────────────────────────
async function syncSource(id) {
    const btn = event.currentTarget;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
    try {
        const res  = await fetch(`?handler=Sync&id=${id}`, {
            method: 'POST', headers: { 'RequestVerificationToken': getToken() }
        });
        const data = await res.json();
        alert(data.ok ? '✓ ' + data.message : '✗ ' + data.message);
        location.reload();
    } catch(e) { alert('Ошибка: ' + e.message); }
    finally { btn.disabled = false; }
}

// ── Удалить источник ────────────────────────────────────────────────
async function deleteSource(id) {
    if (!confirm('Удалить этот источник данных?')) return;
    await fetch(`?handler=Delete&id=${id}`, {
        method: 'POST', headers: { 'RequestVerificationToken': getToken() }
    });
    document.getElementById('ds-' + id)?.remove();
}

// ── Форма открыть/закрыть ───────────────────────────────────────────
document.getElementById('toggleFormBtn').addEventListener('click', () => {
    const f = document.getElementById('addForm');
    f.classList.toggle('open');
    document.getElementById('toggleFormBtn').innerHTML =
        f.classList.contains('open')
            ? '<i class="bi bi-x-lg"></i> Закрыть'
            : '<i class="bi bi-plus-lg"></i> Добавить источник';
});
function closeForm() {
    document.getElementById('addForm').classList.remove('open');
    document.getElementById('toggleFormBtn').innerHTML = '<i class="bi bi-plus-lg"></i> Добавить источник';
}

// ── Утилиты ─────────────────────────────────────────────────────────
function buildPayload() {
    const t = parseInt(document.getElementById('f_type').value) || 0;
    const isFile = t >= 5;
    return {
        name:             document.getElementById('f_name').value.trim(),
        type:             t,
        connectionString: document.getElementById('f_conn')?.value.trim() || '',
        tableName:        (document.getElementById('f_table')?.value || document.getElementById('f_sheet')?.value || '').trim(),
        schemaName:       document.getElementById('f_schema')?.value.trim() || '',
        filePath:         uploadedFilePath,
        xmlItemPath:      document.getElementById('f_xml_item')?.value.trim() || '',
        colName:          document.getElementById('m_name').value.trim(),
        colCategory:      document.getElementById('m_cat').value.trim(),
        colPrice:         document.getElementById('m_price').value.trim(),
        colSpecs:         document.getElementById('m_specs').value.trim(),
        colProductUrl:    document.getElementById('m_url').value.trim(),
        colImageUrl:      document.getElementById('m_img').value.trim(),
        defaultMerchant:  document.getElementById('m_merchant').value.trim(),
        defaultCategory:  document.getElementById('m_default_cat').value,
        autoSync:         document.getElementById('f_autosync').checked,
        autoSyncIntervalH:parseInt(document.getElementById('f_interval').value) || 24,
    };
}

function setStatus(msg, type) {
    const el = document.getElementById('form_status');
    const colors = { success:'#51cf66', error:'#ff6b6b', info:'#adb5bd' };
    el.style.color = colors[type] || '#adb5bd';
    el.textContent = msg;
}

function getToken() {
    return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
}

function jsonHeaders() {
    return {
        'Content-Type': 'application/json',
        'RequestVerificationToken': getToken()
    };
}
</script>
