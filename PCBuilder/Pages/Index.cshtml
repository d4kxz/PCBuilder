@page
@model IndexModel
@{
    ViewData["Title"] = "PC CORE v3 | Professional Configurator";
}

<div class="container py-5">
    <div class="builder-header mb-5 d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-3">
        <div>
            <h1 class="builder-title">Конфигуратор системы</h1>
            <p class="builder-subtitle">Создайте идеальный баланс производительности</p>
        </div>
        <div class="builder-progress-box text-md-end">
            <div class="progress-meta mb-2">
                Готовность: <span id="selectedCount" class="text-accent fw-bold">0</span> / 8
            </div>
            <div class="progress-modern" style="width: 200px;">
                <div id="buildProgressBar" class="progress-modern-bar" style="width:0%"></div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            @{
                var categories = new[] {
                    new { Name = "Процессор",         Icon = "bi-cpu",             Section = "Вычислительное ядро" },
                    new { Name = "Материнская плата",  Icon = "bi-motherboard",     Section = "Вычислительное ядро" },
                    new { Name = "Видеокарта",         Icon = "bi-gpu-card",        Section = "Вычислительное ядро" },
                    new { Name = "Оперативная память", Icon = "bi-memory",          Section = "Память" },
                    new { Name = "Накопитель SSD",     Icon = "bi-device-ssd",      Section = "Память" },
                    new { Name = "Блок питания",       Icon = "bi-lightning-charge",Section = "Энергия" },
                    new { Name = "Корпус",             Icon = "bi-pc-display",      Section = "Энергия" },
                    new { Name = "Охлаждение",         Icon = "bi-fan",             Section = "Энергия" }
                };
                string currentSection = "";
            }

            @foreach (var cat in categories)
            {
                if (currentSection != cat.Section)
                {
                    currentSection = cat.Section;
                    <h5 class="section-title">@currentSection</h5>
                }

                <div class="slot-item empty mb-3" data-slot-category="@cat.Name">
                    <div class="p-3 d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-3">
                            <i class="bi @cat.Icon slot-icon-plain"></i>
                            <div>
                                <div class="slot-label">@cat.Name</div>
                                <div class="slot-value js-slot-res text-white-50">Ожидание выбора...</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn-clear-slot d-none" data-clear-slot="@cat.Name" title="Удалить">
                                <i class="bi bi-trash3"></i>
                            </button>
                            <div class="btn-add-modern">
                                <i class="bi bi-plus-lg"></i>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="summary-panel">
                <h5 class="fw-bold mb-4">Детализация <span class="badge bg-dark text-accent ms-2 border border-secondary">v3.5</span></h5>

                <div id="selectedComponentsPrices" class="summary-list mb-4"></div>

                <div class="analysis-section p-3 rounded-4 mb-4"
                     style="background: rgba(0,0,0,0.2); border: 1px solid var(--border);">
                    <div id="alertStack"></div>

                    <div class="balance-item mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small text-secondary">Баланс CPU / GPU</span>
                            <span id="efficiencyVal" class="small fw-bold">0%</span>
                        </div>
                        <div class="progress-modern">
                            <div id="efficiencyFill" class="progress-modern-bar" style="width:0%"></div>
                        </div>
                    </div>

                    <div class="balance-item">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small text-secondary">Нагрузка БП (TDP)</span>
                            <span id="tdpVal" class="small fw-bold">0W</span>
                        </div>
                        <div class="progress-modern" style="height: 4px;">
                            <div id="tdpFill" class="progress-modern-bar"
                                 style="width:0%; background: var(--success);"></div>
                        </div>
                    </div>
                </div>

                <div class="price-container text-center py-3 mb-4 rounded-4"
                     style="background: rgba(255,255,255,0.03);">
                    <div class="price-label small text-secondary mb-1">ИТОГО К ОПЛАТЕ</div>
                    <div id="totalPriceDisplay" class="total-price text-white">0 ₽</div>
                </div>

                <button class="btn-primary-modern mb-2" id="orderButton">ЗАКАЗАТЬ СБОРКУ</button>
                <button class="btn-save-build w-100" id="saveBuildBtn">
                    <i class="bi bi-bookmark-plus me-1"></i> Сохранить сборку
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ===== MODAL: Выбор компонента ===== -->
<div class="modal fade" id="selectionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content modal-modern text-white">
            <div class="modal-header-custom d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3 flex-grow-1" style="min-width:0">
                    <div class="search-toggle-wrap">
                        <button class="btn-search-toggle" id="searchToggleBtn" title="Поиск">
                            <i class="bi bi-search"></i>
                        </button>
                        <div class="search-slide-wrap" id="searchSlideWrap">
                            <input type="text" id="componentSearchInput"
                                   class="search-slide-input"
                                   placeholder="Поиск по названию...">
                        </div>
                    </div>
                    <div>
                        <h4 class="m-0">Выбор компонента</h4>
                        <span id="modalSubTitle" class="badge bg-primary mt-1"></span>
                    </div>
                </div>
                <button type="button" class="btn-close-custom-v2" data-bs-dismiss="modal" aria-label="Закрыть">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="modal-body p-4">
                <div id="componentsList"
                     class="components-blocks-wrap scroll-slim"
                     style="max-height: 65vh; overflow-y: auto; padding-right: 4px;">
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== MODAL: Сохранить сборку ===== -->
<div class="modal fade" id="saveBuildModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px">
        <div class="modal-content" style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;color:var(--text)">
            <div class="modal-header" style="border-color:var(--border);padding:16px 20px">
                <h5 class="modal-title" style="font-family:'Bebas Neue',sans-serif;letter-spacing:.06em;font-size:1.2rem">
                    <i class="bi bi-bookmark-plus me-2" style="color:var(--accent)"></i>Сохранить сборку
                </h5>
                <button type="button" class="btn-close-custom-v2" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3">
                    <label style="font-size:.8rem;color:var(--text-sub);margin-bottom:6px;display:block">
                        Название сборки
                    </label>
                    <input type="text" id="saveBuildName"
                           placeholder="например, Игровой ПК 2025"
                           style="width:100%;background:var(--bg-card-2,#f5f5f5);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:10px 14px;font-size:.9rem;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s"
                           onfocus="this.style.borderColor='var(--accent)'"
                           onblur="this.style.borderColor='var(--border)'" />
                </div>
                <div id="saveBuildStatus" class="mb-3" style="font-size:.82rem;display:none"></div>
                <button class="btn-primary-modern" id="saveBuildConfirmBtn">Сохранить</button>
            </div>
        </div>
    </div>
</div>

<style>
.btn-save-build {
    background: transparent;
    border: 1px solid var(--accent, #8B5E3C);
    border-radius: 8px;
    color: var(--accent, #8B5E3C);
    font-family: 'Bebas Neue', sans-serif;
    font-size: .95rem; letter-spacing: .08em;
    padding: 10px 16px; cursor: pointer;
    transition: background .2s, color .2s, box-shadow .2s;
    display: flex; align-items: center; justify-content: center; gap: 6px;
}
.btn-save-build:hover {
    background: var(--accent-light, rgba(139,94,60,0.12));
    box-shadow: 0 0 0 2px var(--accent-glow, rgba(139,94,60,0.3));
}
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modalEl         = document.getElementById('selectionModal');
            const bootstrapModal  = new bootstrap.Modal(modalEl);
            const searchInput     = document.getElementById('componentSearchInput');
            const listContainer   = document.getElementById('componentsList');
            const searchToggleBtn = document.getElementById('searchToggleBtn');
            const searchSlideWrap = document.getElementById('searchSlideWrap');

            let currentCategory = '';
            let selectedItems   = JSON.parse(localStorage.getItem('pcBuild') || '{}');

            // ── Поиск ──────────────────────────────────────────
            searchToggleBtn.addEventListener('click', () => {
                const isOpen = searchSlideWrap.classList.toggle('open');
                searchToggleBtn.classList.toggle('active', isOpen);
                if (isOpen) setTimeout(() => searchInput.focus(), 350);
                else { searchInput.value = ''; loadComponents(''); }
            });
            modalEl.addEventListener('hidden.bs.modal', () => {
                searchSlideWrap.classList.remove('open');
                searchToggleBtn.classList.remove('active');
                searchInput.value = '';
            });

            // ── UI ─────────────────────────────────────────────
            function updateUI() {
                document.querySelectorAll('.slot-item').forEach(slot => {
                    const cat      = slot.dataset.slotCategory;
                    const item     = selectedItems[cat];
                    const valEl    = slot.querySelector('.js-slot-res');
                    const clearBtn = slot.querySelector('.btn-clear-slot');
                    const addBtn   = slot.querySelector('.btn-add-modern');

                    if (item) {
                        slot.classList.remove('empty');
                        valEl.textContent = item.name;
                        valEl.classList.replace('text-white-50', 'text-white');
                        clearBtn.classList.remove('d-none');
                        addBtn.classList.add('d-none');
                    } else {
                        slot.classList.add('empty');
                        valEl.textContent = 'Ожидание выбора...';
                        valEl.classList.replace('text-white', 'text-white-50');
                        clearBtn.classList.add('d-none');
                        addBtn.classList.remove('d-none');
                    }
                });

                const count = Object.keys(selectedItems).length;
                document.getElementById('selectedCount').textContent = count;
                document.getElementById('buildProgressBar').style.width = (count / 8 * 100) + '%';

                let total = 0, html = '';
                for (const [cat, item] of Object.entries(selectedItems)) {
                    total += item.selectedPrice;
                    html += `<div class="d-flex justify-content-between mb-2 small">
                                <span class="text-secondary">${cat}</span>
                                <span class="fw-bold">${item.selectedPrice.toLocaleString()} ₽</span>
                             </div>`;
                }
                document.getElementById('selectedComponentsPrices').innerHTML =
                    html || '<div class="text-muted text-center">Сборка не начата</div>';
                document.getElementById('totalPriceDisplay').textContent = total.toLocaleString() + ' ₽';

                calculateAnalysis();
                localStorage.setItem('pcBuild', JSON.stringify(selectedItems));
            }

            // ── Анализ ─────────────────────────────────────────
            function calculateAnalysis() {
                const cpu = selectedItems['Процессор'];
                const gpu = selectedItems['Видеокарта'];
                let balance = 0;
                if (cpu && gpu) {
                    const diff = Math.abs((cpu.powerScore || 0) - (gpu.powerScore || 0));
                    balance = Math.max(0, 100 - diff * 5);
                }
                document.getElementById('efficiencyVal').textContent = Math.round(balance) + '%';
                document.getElementById('efficiencyFill').style.width = balance + '%';

                const totalTdp = Object.values(selectedItems).reduce((s, i) => s + (i.tdp || 0), 0);
                const psu      = selectedItems['Блок питания'];
                const psuWatts = psu ? (psu.psuWatts || 750) : 750;

                document.getElementById('tdpVal').textContent = totalTdp + 'W / ' + psuWatts + 'W';
                const pct  = Math.min(100, totalTdp / psuWatts * 100);
                const fill = document.getElementById('tdpFill');
                fill.style.width      = pct + '%';
                fill.style.background = pct > 90 ? '#f03e3e' : pct > 70 ? '#f59f00' : 'var(--success)';
            }

            // ── Загрузка компонентов ───────────────────────────
            async function loadComponents(term = '') {
                listContainer.innerHTML =
                    '<div class="modal-state-msg"><div class="spinner-border text-accent"></div></div>';
                try {
                    const res  = await fetch(`?handler=SearchComponents&category=${encodeURIComponent(currentCategory)}&term=${encodeURIComponent(term)}`);
                    const data = await res.json();

                    if (!data.length) {
                        listContainer.innerHTML = '<div class="modal-state-msg">Компоненты не найдены</div>';
                        return;
                    }

                    listContainer.innerHTML = data.map(item => {
                        const offersHtml = (item.offers || []).slice(0, 4).map((o, i) => `
                            <div class="offer-cell"
                                 onclick="window.selectComp(
                                    '${item.id}',
                                    '${(item.name || '').replace(/'/g, "\\'")}',
                                    ${o.price},
                                    ${item.powerScore || 0},
                                    ${item.tdp || 0},
                                    ${item.psuWatts || 0},
                                    '${(o.productUrl || '').replace(/'/g, "\\'")}',
                                    '${(o.merchantName || '').replace(/'/g, "\\'")}',
                                    '${(item.image || '').replace(/'/g, "\\'")}')">
                                <span class="offer-cell-num">Вариант ${i + 1}</span>
                                <span class="offer-cell-shop">${o.merchantName || 'Магазин'}</span>
                                <span class="offer-cell-price">${Number(o.price).toLocaleString()} ₽</span>
                            </div>`).join('');

                        return `
                            <div class="comp-block">
                                <div class="comp-block-header">
                                    <img src="${item.image || '/img/no-image.png'}"
                                         class="comp-block-img" alt="${item.name}"
                                         onerror="this.src='/img/no-image.png'">
                                    <div style="min-width:0">
                                        <div class="comp-block-name">${item.name}</div>
                                        ${item.specs ? `<div class="comp-block-specs">${item.specs}</div>` : ''}
                                    </div>
                                </div>
                                <div class="comp-offers-grid">
                                    ${offersHtml || '<div class="offer-cell text-muted small p-3">Нет предложений</div>'}
                                </div>
                            </div>`;
                    }).join('');

                } catch (e) {
                    listContainer.innerHTML = '<div class="modal-state-msg text-danger">Ошибка загрузки</div>';
                }
            }

            // ── Выбор компонента ───────────────────────────────
            window.selectComp = (id, name, price, power, tdp, psuWatts, productUrl, merchantName, image) => {
                selectedItems[currentCategory] = {
                    id, name,
                    selectedPrice: Number(price),
                    powerScore:    power,
                    tdp:           tdp,
                    psuWatts:      psuWatts,
                    productUrl:    productUrl || '',
                    merchantName:  merchantName || '',
                    image:         image || ''
                };
                updateUI();
                bootstrapModal.hide();
            };

            // ── Клик по слоту ──────────────────────────────────
            document.querySelectorAll('.slot-item').forEach(slot => {
                slot.addEventListener('click', e => {
                    if (e.target.closest('.btn-clear-slot')) {
                        delete selectedItems[slot.dataset.slotCategory];
                        updateUI();
                        return;
                    }
                    currentCategory = slot.dataset.slotCategory;
                    document.getElementById('modalSubTitle').textContent = currentCategory;
                    loadComponents();
                    bootstrapModal.show();
                });
            });

            let debounce;
            searchInput.addEventListener('input', () => {
                clearTimeout(debounce);
                debounce = setTimeout(() => loadComponents(searchInput.value), 400);
            });

            // ── Заказать ───────────────────────────────────────
            document.getElementById('orderButton').addEventListener('click', () => {
                if (Object.keys(selectedItems).length < 8) {
                    alert('Пожалуйста, выберите все компоненты перед заказом.');
                    return;
                }
                alert('Заказ сформирован! Проверьте консоль.');
                console.log(selectedItems);
            });

            // ── Сохранить сборку ───────────────────────────────
            const saveBuildModal = new bootstrap.Modal(document.getElementById('saveBuildModal'));

            document.getElementById('saveBuildBtn').addEventListener('click', () => {
                if (Object.keys(selectedItems).length === 0) {
                    alert('Сначала добавьте хотя бы один компонент');
                    return;
                }
                document.getElementById('saveBuildName').value = '';
                document.getElementById('saveBuildStatus').style.display = 'none';
                saveBuildModal.show();
                setTimeout(() => document.getElementById('saveBuildName').focus(), 300);
            });

            document.getElementById('saveBuildConfirmBtn').addEventListener('click', async () => {
                const name     = document.getElementById('saveBuildName').value.trim();
                const statusEl = document.getElementById('saveBuildStatus');

                if (!name) {
                    statusEl.style.display = 'block';
                    statusEl.style.color   = 'var(--danger, #b84c4c)';
                    statusEl.textContent   = 'Введите название сборки';
                    return;
                }

                const caseItem     = selectedItems['Корпус'];
                const caseImageUrl = caseItem?.image || null;
                const total        = Object.values(selectedItems).reduce((s, i) => s + (i.selectedPrice || 0), 0);

                const btn = document.getElementById('saveBuildConfirmBtn');
                btn.disabled    = true;
                btn.textContent = 'Сохраняю...';

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    const res   = await fetch('/Account/Profile?handler=SaveBuild', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({
                            name:         name,
                            totalPrice:   total,
                            buildJson:    JSON.stringify(selectedItems),
                            caseImageUrl: caseImageUrl
                        })
                    });

                    const data = await res.json();

                    if (data.ok) {
                        statusEl.style.display = 'block';
                        statusEl.style.color   = '#4a7c59';
                        statusEl.textContent   = '✓ Сборка сохранена!';
                        setTimeout(() => saveBuildModal.hide(), 1200);
                    } else if (res.status === 401) {
                        statusEl.style.display = 'block';
                        statusEl.style.color   = 'var(--danger, #b84c4c)';
                        statusEl.textContent   = 'Войдите в аккаунт чтобы сохранять сборки';
                    } else {
                        statusEl.style.display = 'block';
                        statusEl.style.color   = 'var(--danger, #b84c4c)';
                        statusEl.textContent   = data.error || 'Ошибка сохранения';
                    }
                } catch (e) {
                    statusEl.style.display = 'block';
                    statusEl.style.color   = 'var(--danger, #b84c4c)';
                    statusEl.textContent   = 'Ошибка сети';
                } finally {
                    btn.disabled    = false;
                    btn.textContent = 'Сохранить';
                }
            });

            updateUI();
        });
    </script>
}
