@page
@model PCBuilder.Pages.Account.LoginModel
@{ ViewData["Title"] = "Вход"; }

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo mb-4">
            <img src="~/img/logo.png" alt="Logo" style="height:40px">
        </div>
        <h2 class="auth-title">Войти</h2>
        <p class="auth-sub">Твои сборки ждут тебя</p>

        <form method="post" class="mt-4">
            <div asp-validation-summary="ModelOnly" class="auth-error mb-3"></div>

            <div class="auth-field mb-3">
                <label asp-for="Input.UserName">Имя пользователя или Email</label>
                <input asp-for="Input.UserName" class="auth-input" placeholder="username или email" autocomplete="username" />
                <span asp-validation-for="Input.UserName" class="auth-field-error"></span>
            </div>

            <div class="auth-field mb-3">
                <label asp-for="Input.Password">Пароль</label>
                <input asp-for="Input.Password" type="password" class="auth-input" placeholder="••••••" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="auth-field-error"></span>
            </div>

            <div class="d-flex align-items-center justify-content-between mb-4">
                <label style="display:flex;align-items:center;gap:8px;font-size:.82rem;color:var(--text-sub,#666);cursor:pointer">
                    <input asp-for="Input.RememberMe" type="checkbox" />
                    Запомнить меня
                </label>
            </div>

            <button type="submit" class="auth-btn">Войти</button>
        </form>

        <div class="auth-footer mt-4">
            Нет аккаунта? <a href="/Account/Register">Зарегистрироваться</a>
        </div>
    </div>
</div>

<!-- Стили из Register.cshtml переиспользуются через Layout -->
<style>
.auth-wrap { min-height:calc(100vh - 60px); display:flex; align-items:center; justify-content:center; padding:40px 16px; }
.auth-card { background:var(--bg-card,#fff); border:1px solid var(--border,#e0e0e0); border-radius:16px; padding:40px; width:100%; max-width:420px; box-shadow:var(--shadow,0 2px 16px rgba(0,0,0,0.08)); }
.auth-logo { text-align:center; }
.auth-title { font-family:'Bebas Neue',sans-serif; font-size:1.8rem; letter-spacing:.06em; color:var(--text,#1a1a1a); text-align:center; }
.auth-sub { text-align:center; color:var(--text-sub,#666); font-size:.85rem; margin-top:4px; }
.auth-field label { display:block; font-size:.8rem; font-weight:500; color:var(--text-sub,#666); margin-bottom:6px; letter-spacing:.03em; }
.auth-input { width:100%; background:var(--bg-card-2,#f5f5f5); border:1px solid var(--border,#e0e0e0); border-radius:8px; color:var(--text,#1a1a1a); padding:10px 14px; font-size:.9rem; font-family:'DM Sans',sans-serif; outline:none; transition:border-color .2s,box-shadow .2s; }
.auth-input:focus { border-color:var(--accent,#8B5E3C); box-shadow:0 0 0 3px var(--accent-glow,rgba(139,94,60,0.15)); }
.auth-field-error { font-size:.75rem; color:var(--danger,#b84c4c); margin-top:4px; display:block; }
.auth-error { background:rgba(184,76,76,.08); border:1px solid rgba(184,76,76,.2); border-radius:8px; padding:10px 14px; font-size:.85rem; color:var(--danger,#b84c4c); }
.auth-btn { width:100%; background:var(--accent,#8B5E3C); border:none; border-radius:8px; color:#fff; font-family:'Bebas Neue',sans-serif; font-size:1rem; letter-spacing:.1em; padding:13px; cursor:pointer; transition:opacity .2s,box-shadow .2s; }
.auth-btn:hover { opacity:.9; box-shadow:0 0 0 3px var(--accent-glow,rgba(139,94,60,0.3)); }
.auth-footer { text-align:center; font-size:.85rem; color:var(--text-sub,#666); }
.auth-footer a { color:var(--accent,#8B5E3C); font-weight:600; text-decoration:none; }
.auth-footer a:hover { text-decoration:underline; }
</style>
