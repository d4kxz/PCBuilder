<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PC CORE</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <div class="neon-background-container"></div>

    <div class="accent-line"></div>

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark border-bottom border-white border-opacity-10 py-3">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center" asp-page="/Index">
                    <span class="brand-dot me-2"></span> PC<span class="text-accent">CORE</span>
                </a>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1 container py-5">
        @RenderBody()
    </main>

    <footer class="py-3 border-top border-white border-opacity-10">
        <div class="container text-center">
            <span class="text-muted small">© 2026 PC-CORE Architecture Engine</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>